# Postgres (matches docker-compose.dev.yml; port 5436 avoids clash with host Postgres on 5432)
DATABASE_URL=postgres://postgres:postgres@localhost:5436/feedback_tool

# Postgres pool + safety timeouts
# DB_POOL_MAX                caps concurrent connections per worker (default 10).
# DB_STATEMENT_TIMEOUT_MS    kills any single query exceeding this many ms (default 30000).
# DB_IDLE_TX_TIMEOUT_MS      kills connections held open by a leaked BEGIN (default 10000).
DB_POOL_MAX=10
DB_STATEMENT_TIMEOUT_MS=30000
DB_IDLE_TX_TIMEOUT_MS=10000

# better-auth
BETTER_AUTH_SECRET=replace-me-with-32-random-bytes
# BETTER_AUTH_URL must be the SAME origin as the dashboard UI. The UI sends
# session cookies with `credentials: include`, which the browser only allows
# when the API origin matches the page origin (or when the API explicitly
# emits credentialed CORS headers — which the dashboard does not). Split-origin
# deployments (e.g. dashboard.example.com + auth.example.com) require extra
# CORS middleware; see apps/dashboard/app/composables/useApi.ts.
BETTER_AUTH_URL=http://localhost:3000

# OAuth providers (leave blank to hide the button on the sign-in page)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email
# `console` prints verification URLs / invite links to stdout — the dev default,
# no external network, no rate-limit friction. Switch to `smtp` for real email.
# `ethereal` uses nodemailer's test SMTP (preview URL in logs) — occasionally
# rate-limited, prefer `console` for local dev.
MAIL_PROVIDER=console
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Feedback Tool <no-reply@localhost>"

# ─────────────────────────────────────────────────────────────────
# Storage — attachments (screenshots, logs)
# ─────────────────────────────────────────────────────────────────
# `local` writes to STORAGE_LOCAL_ROOT (Docker volume or mounted dir).
# `s3` writes to any S3-compatible endpoint (see provider recipes below).
# No automatic fallback — pick ONE at deploy time.
STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=./.data/attachments

# --- When STORAGE_DRIVER=s3 ---
# S3_BUCKET=feedback-tool-attachments
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=<required>
# S3_SECRET_ACCESS_KEY=<required>
#
# For AWS S3 (virtual-hosted addressing):
#   S3_VIRTUAL_HOSTED=true
#   # S3_ENDPOINT left empty — defaults to AWS
#
# For Cloudflare R2:
#   S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   S3_REGION=auto
#
# For Backblaze B2:
#   S3_ENDPOINT=https://s3.<region>.backblazeb2.com
#   S3_REGION=<region>   # e.g. us-west-002
#
# For Hetzner Object Storage:
#   S3_ENDPOINT=https://<region>.your-objectstorage.com
#   S3_REGION=<region>   # e.g. nbg1
#
# For self-run MinIO / Garage / SeaweedFS:
#   S3_ENDPOINT=http://<host>:<port>
#   S3_REGION=<anything>   # most self-hosted stores ignore this

# Attachment signed URLs
# Used when generating time-limited download links for screenshots / attachments.
# Generate with: openssl rand -hex 32
ATTACHMENT_URL_SECRET=replace-me-with-32-random-bytes

# ─────────────────────────────────────────────────────────────────
# GitHub integration (GitHub App)
# ─────────────────────────────────────────────────────────────────
GITHUB_APP_ID=
# PEM contents OR path to a .pem file (relative to apps/dashboard/ or absolute)
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_SLUG=feedback-tool

# Intake limits
INTAKE_RATE_PER_KEY=60
INTAKE_RATE_PER_IP=20
# Stricter bucket for anonymous submissions (no reporter.userId)
INTAKE_RATE_PER_KEY_ANON=10
INTAKE_MAX_BYTES=5242880
# Set to `false` during SDK rollout if older clients don't send `_dwellMs`
INTAKE_REQUIRE_DWELL=true
# Minimum ms between widget open and submit
INTAKE_MIN_DWELL_MS=1500
# Only set to `true` when behind a trusted reverse proxy (affects per-IP rate limit keying)
TRUST_XFF=false
# Optional; webhook body cap before HMAC work
GITHUB_WEBHOOK_MAX_BYTES=1048576

# ─────────────────────────────────────────────────────────────────
# Rate limit storage
# ─────────────────────────────────────────────────────────────────
# Leave blank (default) for in-process; set to `postgres` for shared across workers
# (uses rate_limit_buckets table — requires the dashboard DB migration).
RATE_LIMIT_STORE=

# ─────────────────────────────────────────────────────────────────
# Auth endpoint rate limits (H2)
# ─────────────────────────────────────────────────────────────────
# Max attempts per IP per 15-minute window against sign-in and magic-link
# verify paths. Industry standard is 5; be more generous than 1/sec because
# humans retry typos. Does NOT apply to /session, /sign-out, or OAuth
# /callback/* paths.
AUTH_RATE_PER_IP_PER_15MIN=5
# Auth rate limiting is enabled in production by default. Set to `true` to
# force-enable in dev/test (the auth rate-limit test suite sets this). Set to
# `false` to disable even in production (escape hatch).
AUTH_RATE_LIMIT_ENABLED=

# ─────────────────────────────────────────────────────────────────
# SDK dev server
# ─────────────────────────────────────────────────────────────────
# Path to the built SDK IIFE bundle served at /sdk/feedback-tool.iife.js
# Leave blank to use the default build output path.
SDK_PATH=
