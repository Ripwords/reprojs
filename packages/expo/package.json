{
  "name": "@reprojs/expo",
  "version": "0.1.0",
  "description": "Expo SDK for Repro — submit annotated screenshots, logs, and device context to the Repro dashboard.",
  "keywords": [
    "bug-report",
    "expo",
    "feedback",
    "react-native",
    "repro"
  ],
  "license": "MIT",
  "author": "JJ Teoh",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ripwords/reprojs.git",
    "directory": "packages/expo"
  },
  "files": [
    "dist",
    "app.plugin.js"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./app.plugin.js": "./app.plugin.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@expo/config-plugins": "^8.0.0",
    "@reprojs/sdk-utils": "workspace:*",
    "@reprojs/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "bun-types": "^1.3.12",
    "expo": "^52.0.0",
    "react": "^18.3.1",
    "react-native": "^0.76.0",
    "tsdown": "^0.21.9",
    "typescript": "^5.8"
  },
  "peerDependencies": {
    "@react-native-async-storage/async-storage": ">=1.23.0",
    "@react-native-community/netinfo": ">=11.3.0",
    "expo": ">=52.0.0",
    "expo-constants": ">=16.0.0",
    "expo-device": ">=6.0.0",
    "expo-file-system": ">=17.0.0",
    "react": ">=18.3.0",
    "react-native": ">=0.74.0",
    "react-native-gesture-handler": ">=2.16.0",
    "react-native-svg": ">=15.0.0",
    "react-native-view-shot": ">=3.8.0"
  }
}
